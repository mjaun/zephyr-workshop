{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Target",
            "type": "cortex-debug",
            "servertype": "pyocd",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "interface": "swd",
            "targetId": "STM32U385RGTXQ",
            "device": "STM32U385RGT6Q",
            "gdbPath": "${command:zephyr-ide.get-gdb-path}",
            "executable": "${command:zephyr-ide.get-zephyr-elf}",
            "svdFile": "/workdir/boards/demo/STM32U385.svd",
            "runToEntryPoint": "main"
        },
        {
            "name": "Attach Target",
            "type": "cortex-debug",
            "servertype": "pyocd",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "interface": "swd",
            "targetId": "STM32U385RGTXQ",
            "device": "STM32U385RGT6Q",
            "gdbPath": "${command:zephyr-ide.get-gdb-path}",
            "executable": "${command:zephyr-ide.get-zephyr-elf}"
        },
        {
            "name": "Debug Sim",
            "type": "cppdbg",
            "request": "launch",
            "MIMode": "gdb",
            "args": [],
            "cwd": "${workspaceFolder}",
            "program": "${command:zephyr-ide.get-zephyr-elf-dir}/zephyr.exe",
            "miDebuggerPath": "${command:zephyr-ide.get-gdb-path}",
        },
        {
            "name": "Attach Sim",
            "type": "cppdbg",
            "request": "attach",
            "MIMode": "gdb",
            "program": "${command:zephyr-ide.get-zephyr-elf-dir}/zephyr.exe",
            "miDebuggerPath": "${command:zephyr-ide.get-gdb-path}",
        }
    ]
}